{
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "bash scripts/standards-hook.sh",
            "timeout": 30
          }
        ]
      }
    ]
  },
  "disallowedTools": [
    "Bash(git checkout:*)",
    "Bash(git reset:*)",
    "Bash(git checkout -- *)",
    "Bash(git reset --hard:*)",
    "Bash(git clean:*)",
    "Bash(git add:*)",
    "Bash(git commit:*)",
    "Bash(git push:*)",
    "Bash(git pull:*)",
    "Bash(git fetch:*)",
    "Bash(git merge:*)",
    "Bash(git rebase:*)",
    "Bash(git cherry-pick:*)",
    "Bash(git revert:*)",
    "Bash(git branch -d:*)",
    "Bash(git branch -D:*)",
    "Bash(git tag:*)",
    "Bash(git stash:*)"
  ]
}
