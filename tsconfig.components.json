{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "noEmit": false,
    "outDir": "dist",
    "rootDir": ".",
    "declaration": true,
    "emitDeclarationOnly": false,
    "sourceMap": true,
    "noUnusedLocals": false,
    "noUnusedParameters": false
  },
  "include": ["components"],
  "exclude": ["src", "components/**/*.test.ts", "components/**/*.spec.ts", "components/**/*.html", "components/**/demo*", "components/**/*.md"]
}