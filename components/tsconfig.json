{
  "extends": "../tsconfig.json",
  "compilerOptions": {
    "noEmit": false,
    "outDir": "../dist/components",
    "rootDir": ".",
    "declaration": true,
    "emitDeclarationOnly": false,
    "sourceMap": true,
    "noUnusedLocals": false,
    "noUnusedParameters": false,
    "paths": {
      "snice": ["../dist/index.ts", "../src/index.ts"]
    }
  },
  "include": ["."],
  "exclude": ["**/*.test.ts", "**/*.spec.ts", "**/*.html", "**/demo*", "**/*.md"]
}