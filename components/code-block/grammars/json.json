{
  "name": "json",
  "fileTypes": ["json", "jsonc"],
  "defaultToken": "",
  "formatters": {
    "pretty": {
      "tabSize": 2,
      "useTabs": false,
      "newlineAfter": "[{\\[,]",
      "newlineBefore": "[}\\]]",
      "spaceAfter": "[:]",
      "indent": "[{\\[]",
      "dedent": "[}\\]]",
      "skipStrings": true,
      "skipComments": true
    }
  },
  "tokenizer": {
    "root": [
      ["\"(?:[^\"\\\\]|\\\\.)*\"(?=\\s*:)", "property"],
      ["\"", "string", "@string"],
      ["-?\\b\\d+\\.?\\d*(?:e[+-]?\\d+)?\\b", "number"],
      ["\\b(?:true|false)\\b", "constant"],
      ["\\bnull\\b", "constant"],
      ["[{}\\[\\],:]", "punctuation"]
    ],
    "string": [
      ["[^\"\\\\]+", "string"],
      ["\\\\.", "string"],
      ["\"", "string", "@pop"]
    ]
  }
}
