{
  "name": "html",
  "fileTypes": ["html", "htm", "xml", "svg"],
  "defaultToken": "",
  "tokenizer": {
    "root": [
      ["<!--[\\s\\S]*?-->", "comment"],
      ["<!DOCTYPE[^>]*>", "keyword"],
      ["<script[^>]*>", "tag", "@scriptContent"],
      ["<style[^>]*>", "tag", "@styleContent"],
      ["<\\/[\\w-]+\\s*>", "tag"],
      ["<[\\w-]+", "tag", "@tag"],
      ["&\\w+;", "constant"]
    ],
    "tag": [
      ["\\s+", ""],
      ["\\/>", "tag", "@pop"],
      [">", "tag", "@pop"],
      ["\"[^\"]*\"", "attr-value"],
      ["'[^']*'", "attr-value"],
      ["[\\w-]+(?=\\s*=)", "attr-name"],
      ["=", "operator"],
      ["[\\w-]+", "attr-name"]
    ],
    "scriptContent": [
      ["<\\/script\\s*>", "tag", "@pop"],
      ["\\/\\/.*$", "comment"],
      ["\\/\\*", "comment", "@blockComment"],
      ["`", "string", "@template"],
      ["\"(?:[^\"\\\\]|\\\\.)*\"", "string"],
      ["'(?:[^'\\\\]|\\\\.)*'", "string"],
      ["\\b(?:const|let|var|function|return|if|else|for|while|do|class|new|this|import|export|from|async|await|try|catch|throw|finally|switch|case|break|continue|default|typeof|instanceof|of|in|void|delete|yield|static|extends|super)\\b", "keyword"],
      ["\\b(?:true|false|null|undefined|NaN|Infinity)\\b", "constant"],
      ["\\b\\d+\\.?\\d*(?:e[+-]?\\d+)?\\b", "number"],
      ["\\b0x[0-9a-fA-F]+\\b", "number"],
      ["\\b[A-Z][\\w]*\\b", "class-name"],
      ["\\b[\\w]+(?=\\s*\\()", "function"],
      ["=>", "keyword"],
      ["[{}()\\[\\];,.]", "punctuation"],
      ["[+\\-*/%=<>!&|^~?:]+", "operator"]
    ],
    "styleContent": [
      ["<\\/style\\s*>", "tag", "@pop"],
      ["\\/\\*", "comment", "@blockComment"],
      ["@[\\w-]+", "keyword"],
      ["[.#][\\w-]+", "tag"],
      [":[:\\w-]+", "keyword"],
      ["[a-z-]+(?=\\s*:)", "attr-name"],
      ["#[0-9a-fA-F]{3,8}", "number"],
      ["\\b\\d+\\.?\\d*(?:px|em|rem|%|vh|vw|s|ms|deg|fr)?\\b", "number"],
      ["\"(?:[^\"\\\\]|\\\\.)*\"", "string"],
      ["'(?:[^'\\\\]|\\\\.)*'", "string"],
      ["[{}();,:]", "punctuation"]
    ],
    "blockComment": [
      ["[^*]+", "comment"],
      ["\\*\\/", "comment", "@pop"],
      ["[*]", "comment"]
    ],
    "template": [
      ["\\$\\{", "punctuation", "@interpolation"],
      ["[^`$\\\\]+", "string"],
      ["\\\\.", "string"],
      ["\\$", "string"],
      ["`", "string", "@pop"]
    ],
    "interpolation": [
      ["\\}", "punctuation", "@pop"],
      { "include": "@scriptContent" }
    ]
  }
}
