{
  "name": "snice",
  "version": "4.28.0",
  "type": "module",
  "description": "A decorator-driven web component library with differential rendering, routing, controllers, and 130+ ready-made UI components. Use as much or as little as you want. Zero dependencies, works anywhere.",
  "main": "dist/index.cjs",
  "module": "dist/index.esm.js",
  "browser": "dist/index.iife.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.esm.js",
      "require": "./dist/index.cjs",
      "browser": "./dist/index.iife.js",
      "types": "./dist/index.d.ts"
    },
    "./symbols": {
      "import": "./dist/symbols.esm.js",
      "require": "./dist/symbols.cjs",
      "types": "./dist/symbols.d.ts"
    },
    "./transitions": {
      "import": "./dist/transitions.esm.js",
      "require": "./dist/transitions.cjs",
      "types": "./dist/transitions.d.ts"
    },
    "./react": {
      "types": "./adapters/react/index.d.ts",
      "import": "./adapters/react/index.js"
    },
    "./react/*": {
      "types": "./adapters/react/*.d.ts",
      "import": "./adapters/react/*.js"
    },
    "./components/theme/theme.css": "./dist/components/theme/theme.css",
    "./components/*": {
      "import": "./dist/components/*.js",
      "types": "./dist/components/*.d.ts"
    }
  },
  "bin": {
    "snice": "./bin/snice.js",
    "snice-mcp": "./bin/mcp-server.js"
  },
  "files": [
    "dist",
    "adapters",
    "bin",
    "README.md",
    "docs"
  ],
  "keywords": [
    "web components",
    "web-components",
    "webcomponents",
    "web-component",
    "custom elements",
    "custom-elements",
    "custom-element",
    "shadow dom",
    "typescript",
    "framework",
    "decorators",
    "vanilla js",
    "frontend",
    "spa",
    "routing",
    "no virtual dom",
    "lightweight",
    "ui",
    "ui-components",
    "component-library",
    "reactive",
    "zero-dependencies",
    "html",
    "css",
    "web standards",
    "lit alternative",
    "stencil alternative",
    "components"
  ],
  "author": "hedzer",
  "license": "MIT",
  "homepage": "https://snice.dev",
  "repository": {
    "type": "git",
    "url": "https://github.com/Hedzer/snice.git"
  },
  "bugs": {
    "url": "https://gitlab.com/Hedzer/snice/-/issues"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "dev": "node scripts/dev.js",
    "dev:framework": "vite",
    "sync-versions": "node scripts/sync-template-versions.js",
    "prebuild": "[ -z \"$NEXT_VERSION\" ] && npm run sync-versions || true",
    "build": "npm run build:core && npm run build:cdn && npm run build:react",
    "build:core": "rm -rf dist && rollup -c && npm run build:types",
    "build:types": "tsc --project components/tsconfig.json --emitDeclarationOnly",
    "build:cdn": "rollup -c rollup.config.cdn.js && cp dist/cdn/*/snice-*.min.js public/components/ && node scripts/update-cdn-sizes.js",
    "build:showcases": "node public/build-showcases.js",
    "build:react": "npm run generate:react-adapters && tsc --project adapters/react/tsconfig.json",
    "build:test": "rollup -c rollup.config.test.js",
    "generate:react-adapters": "node scripts/generate-react-adapters.js",
    "generate:react-tests": "node scripts/generate-react-tests.js",
    "preview": "vite preview",
    "pretest": "npm run sync-versions",
    "test": "npm run test:all",
    "test:watch": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest --coverage",
    "test:src": "npm run build:test && vitest run tests/components tests/channel.test.ts tests/channel-simple.test.ts tests/decorators.test.ts tests/dispatch.test.ts tests/form-associated.test.ts tests/router.test.ts tests/cli-create-app.test.ts",
    "test:built": "npm run build:test && TEST_BUILT=true vitest run tests/components tests/channel.test.ts tests/channel-simple.test.ts tests/decorators.test.ts tests/dispatch.test.ts tests/form-associated.test.ts tests/router.test.ts tests/cli-create-app.test.ts",
    "test:cdn": "vitest run tests/cdn-builds.test.ts",
    "test:cdn-runtime": "vitest run tests/cdn-runtime.test.ts",
    "test:react-adapters": "vitest run tests/react-adapters",
    "test:live:components": "npx playwright test tests/live/components --config=tests/playwright.config.ts",
    "test:live:templates": "npx playwright test tests/live/templates --config=tests/playwright.config.ts",
    "test:all": "npm run test:src && npm run test:built && npm run test:cdn && npm run test:cdn-runtime && npm run test:react-adapters",
    "prerelease": "NEXT_VERSION=$(node scripts/get-next-version.js) && node scripts/sync-template-versions.js $NEXT_VERSION && npm run build",
    "release": "semantic-release --no-ci",
    "postrelease": "npm run website:deploy",
    "release:dry": "semantic-release --dry-run --no-ci",
    "website:build": "node scripts/build-website.js && npm run build:showcases",
    "website:build:full": "npm run build:cdn && npm run website:build",
    "dev:website": "npm run website:build && vite --port 52891",
    "website:dev": "npm run website:build && vite --port 52891",
    "website:deploy": "npm run website:build:full && node scripts/build-deploy.js && npx wrangler deploy",
    "website:test": "vitest run tests/website.test.ts",
    "website:test:render": "npm run website:build && cd public && python3 -m http.server 52891 & sleep 2 && npx playwright test tests/website-render.test.ts; kill %1",
    "screenshots": "node scripts/take-screenshots.mjs"
  },
  "devDependencies": {
    "@playwright/test": "^1.56.1",
    "@rollup/plugin-node-resolve": "^16.0.1",
    "@rollup/plugin-terser": "^0.4.4",
    "@rollup/plugin-typescript": "^12.1.4",
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/commit-analyzer": "^13.0.1",
    "@semantic-release/exec": "^7.1.0",
    "@semantic-release/git": "^10.0.1",
    "@semantic-release/gitlab": "^13.2.6",
    "@semantic-release/npm": "^12.0.2",
    "@semantic-release/release-notes-generator": "^14.0.3",
    "@swc/core": "^1.13.5",
    "@types/node": "^20.0.0",
    "@types/react": "^19.2.2",
    "@types/react-dom": "^19.2.2",
    "@vitest/ui": "^1.0.0",
    "clean-css": "^5.3.3",
    "happy-dom": "^12.0.0",
    "qrcode": "^1.5.4",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "rollup": "^4.50.2",
    "semantic-release": "^24.2.7",
    "typescript": "^5.9.2",
    "unplugin-swc": "^1.5.7",
    "vite": "^5.0.10",
    "vitest": "^1.0.0"
  },
  "dependencies": {
    "pica-route": "^1.1.2",
    "tslib": "^2.8.1"
  },
  "peerDependencies": {
    "tslib": "^2.8.1"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    },
    "react-dom": {
      "optional": true
    }
  },
  "optionalDependencies": {
    "react": ">=17.0.0",
    "react-dom": ">=17.0.0"
  }
}
