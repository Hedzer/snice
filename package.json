{
  "name": "snice",
  "version": "3.10.0",
  "type": "module",
  "description": "Imperative TypeScript framework for building vanilla web components with decorators, differential rendering, routing, and controllers. No virtual DOM, no build complexity.",
  "main": "dist/index.cjs",
  "module": "dist/index.esm.js",
  "browser": "dist/index.iife.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.esm.js",
      "require": "./dist/index.cjs",
      "browser": "./dist/index.iife.js",
      "types": "./dist/index.d.ts"
    },
    "./symbols": {
      "import": "./dist/symbols.esm.js",
      "require": "./dist/symbols.cjs",
      "types": "./dist/symbols.d.ts"
    },
    "./transitions": {
      "import": "./dist/transitions.esm.js",
      "require": "./dist/transitions.cjs",
      "types": "./dist/transitions.d.ts"
    },
    "./components/theme/theme.css": "./dist/components/theme/theme.css",
    "./components/*": {
      "import": "./dist/components/*.js",
      "types": "./dist/components/*.d.ts"
    }
  },
  "bin": {
    "snice": "./bin/snice.js"
  },
  "files": [
    "dist",
    "bin",
    "README.md",
    "docs"
  ],
  "keywords": [
    "web components",
    "typescript",
    "framework",
    "decorators",
    "custom elements",
    "vanilla js",
    "frontend",
    "spa",
    "routing",
    "imperative",
    "no virtual dom",
    "lightweight",
    "minimal",
    "controllers",
    "mvc",
    "shadow dom",
    "lit alternative",
    "stencil alternative",
    "web standards"
  ],
  "author": "hedzer",
  "license": "MIT",
  "homepage": "https://gitlab.com/Hedzer/snice#readme",
  "repository": {
    "type": "git",
    "url": "git@gitlab.com:Hedzer/snice.git"
  },
  "bugs": {
    "url": "https://gitlab.com/Hedzer/snice/-/issues"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "dev": "vite",
    "sync-versions": "node scripts/sync-template-versions.js",
    "prebuild": "npm run sync-versions",
    "build": "rm -rf dist && rollup -c && npm run build:types",
    "build:types": "tsc --project components/tsconfig.json --emitDeclarationOnly",
    "build:test": "rollup -c rollup.config.test.js",
    "preview": "vite preview",
    "pretest": "npm run sync-versions",
    "test": "npm run build:test && vitest run",
    "test:watch": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest --coverage",
    "test:src": "npm run build:test && vitest run",
    "test:built": "npm run build:test && TEST_BUILT=true vitest run",
    "test:all": "npm run test:src && npm run test:built",
    "prerelease": "npm run build",
    "release": "semantic-release --no-ci",
    "release:dry": "semantic-release --dry-run --no-ci"
  },
  "devDependencies": {
    "@playwright/test": "^1.56.1",
    "@rollup/plugin-node-resolve": "^16.0.1",
    "@rollup/plugin-terser": "^0.4.4",
    "@rollup/plugin-typescript": "^12.1.4",
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/commit-analyzer": "^13.0.1",
    "@semantic-release/git": "^10.0.1",
    "@semantic-release/gitlab": "^13.2.6",
    "@semantic-release/npm": "^12.0.2",
    "@semantic-release/release-notes-generator": "^14.0.3",
    "@swc/core": "^1.13.5",
    "@types/node": "^20.0.0",
    "@vitest/ui": "^1.0.0",
    "clean-css": "^5.3.3",
    "happy-dom": "^12.0.0",
    "qrcode": "^1.5.4",
    "rollup": "^4.50.2",
    "semantic-release": "^24.2.7",
    "typescript": "^5.9.2",
    "unplugin-swc": "^1.5.7",
    "vite": "^5.0.10",
    "vitest": "^1.0.0"
  },
  "dependencies": {
    "pica-route": "^1.1.2",
    "tslib": "^2.8.1"
  },
  "peerDependencies": {
    "tslib": "^2.8.1"
  }
}
